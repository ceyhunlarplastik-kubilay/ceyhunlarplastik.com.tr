// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////

model User {
  id                              String                        @id @default(uuid())
  cognitoSub                      String                        @unique
  email                           String                        @unique
  identifier                      String
  firstName                       String?
  lastName                        String?
  imageKey                        String?
  phone                           String?
  groups                          String[]
  accessStatus                    UserAccessStatus              @default(PENDING_REVIEW)
  accessStatusChangedAt           DateTime?
  accessStatusChangedByUserId     String?
  accessStatusReason              String?                       @db.Text
  supplierId                      String?
  supplier                        Supplier?                     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  customerId                      String?
  customer                        Customer?                     @relation("CustomerPortalUsers", fields: [customerId], references: [id], onDelete: SetNull)
  customerContactTitle            String?
  customerContactDepartment       String?
  isPrimaryCustomerContact        Boolean                       @default(false)
  isActive                        Boolean                       @default(true)
  assignedSalesCustomers          Customer[]                    @relation("AssignedSalesUser")
  convertedCustomers              Customer[]                    @relation("CustomerConvertedBy")
  assignedPurchasingSuppliers     Supplier[]                    @relation("SupplierPurchasingAssignments")
  requestedBusinessRequests       BusinessRequest[]             @relation("BusinessRequestRequestedBy")
  requestedOrders                 Order[]                       @relation("CustomerOrderRequestedBy")
  assignedBusinessRequestSteps    BusinessRequestApprovalStep[] @relation("BusinessRequestStepAssignedUser")
  decidedBusinessRequestSteps     BusinessRequestApprovalStep[] @relation("BusinessRequestStepDecidedBy")
  activityLogs                    ActivityLog[]                 @relation("ActivityLogActor")
  createdCustomerFeaturedProducts CustomerFeaturedProduct[]     @relation("CustomerFeaturedProductCreatedBy")
  createdCustomerAssignedProducts CustomerAssignedProduct[]     @relation("CustomerAssignedProductCreatedBy")
  ownedCustomerVisits             CustomerVisit[]               @relation("CustomerVisitOwner")
  createdCustomerVisits           CustomerVisit[]               @relation("CustomerVisitCreatedBy")
  createdCustomerSpecialPrices    CustomerVariantSpecialPrice[] @relation("CustomerVariantSpecialPriceCreatedBy")
  approvedCustomerSpecialPrices   CustomerVariantSpecialPrice[] @relation("CustomerVariantSpecialPriceApprovedBy")
  notifications                   UserNotification[]
  verifiedCustomerAddresses       CustomerAddress[]             @relation("CustomerAddressVerifiedByUser")
  customerInvitations             UserInvitation[]              @relation("CustomerPortalInvitationUser")
  sentCustomerInvitations         UserInvitation[]              @relation("CustomerPortalInvitationInvitedByUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, isPrimaryCustomerContact])
  @@index([accessStatus, createdAt])
}

enum UserAccessStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

model UserNotification {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      UserNotificationType
  title     String
  message   String               @db.Text
  data      Json?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
}

enum UserNotificationType {
  ACCESS_STATUS_CHANGED
  ROLE_CHANGED
  ASSIGNMENT_CHANGED
  REQUEST_CREATED
  APPROVAL_REQUIRED
  REQUEST_DECIDED
}

///////////////////////////////////////////////////////
// COLOR
///////////////////////////////////////////////////////

model Color {
  id       String      @id @default(uuid())
  system   ColorSystem @default(RAL)
  code     String
  name     String
  hex      String
  rgbR     Int?
  rgbG     Int?
  rgbB     Int?
  isActive Boolean     @default(true)

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([system, code])
}

enum ColorSystem {
  RAL
  PANTONE
  NCS
  CUSTOM
}

///////////////////////////////////////////////////////
// CATEGORY
///////////////////////////////////////////////////////

model Category {
  id                       String   @id @default(uuid())
  code                     Int
  name                     String
  slug                     String   @unique
  allowedAttributeValueIds String[] @default([])

  products     Product[]
  assets       Asset[]
  translations CategoryTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
}

model CategoryTranslation {
  id         String @id @default(uuid())
  categoryId String
  locale     String @db.VarChar(16)
  name       String
  slug       String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([locale, categoryId])
}

///////////////////////////////////////////////////////
// PRODUCT (10.11)
///////////////////////////////////////////////////////

model Product {
  id String @id @default(uuid())

  code String // 10.11
  name String
  slug String @unique

  description String? @db.Text

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  variants            ProductVariant[]
  assets              Asset[]
  attributeValues     ProductAttributeValue[]
  industrialUsages    ProductIndustrialUsage[]
  featuredByCustomers CustomerFeaturedProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
  @@index([categoryId])
}

model ProductAttribute {
  id String @id @default(uuid())

  code String @unique // usage_area, model_type, connection_type, profile_type, material_type, usage_type, hat_type
  name String

  displayOrder         Int     @default(0)
  isActive             Boolean @default(true)
  isCustomerAssignable Boolean @default(false)

  values ProductAttributeValue[]
  translations ProductAttributeTranslation[]
  valueTranslations ProductAttributeValueTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductAttributeTranslation {
  id                 String @id @default(uuid())
  productAttributeId String
  locale             String @db.VarChar(16)
  name               String

  productAttribute ProductAttribute @relation(fields: [productAttributeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productAttributeId, locale])
  @@index([locale, productAttributeId])
}

model ProductAttributeValue {
  id String @id @default(uuid())

  name String
  slug String

  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  parentValueId String?
  parentValue   ProductAttributeValue?  @relation("AttributeValueHierarchy", fields: [parentValueId], references: [id], onDelete: SetNull)
  childValues   ProductAttributeValue[] @relation("AttributeValueHierarchy")

  // 🔥 MANY TO MANY
  products                          Product[]
  assets                            Asset[]
  translations                      ProductAttributeValueTranslation[]
  customerSectors                   Customer[]                         @relation("CustomerSector")
  customerProductionGroups          Customer[]                         @relation("CustomerProductionGroup")
  customerUsageAreas                Customer[]                         @relation("CustomerUsageAreas")
  customerAttributeAssignments      CustomerAttributeValueAssignment[]
  productIndustrialSectors          ProductIndustrialUsage[]           @relation("ProductIndustrialUsageSector")
  productIndustrialProductionGroups ProductIndustrialUsage[]           @relation("ProductIndustrialUsageProductionGroup")
  productIndustrialUsageAreas       ProductIndustrialUsage[]           @relation("ProductIndustrialUsageArea")

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attributeId, name])
  @@index([attributeId])
  @@index([parentValueId])
}

model ProductAttributeValueTranslation {
  id                      String @id @default(uuid())
  productAttributeValueId String
  attributeId             String
  locale                  String @db.VarChar(16)
  name                    String
  slug                    String

  productAttributeValue ProductAttributeValue @relation(fields: [productAttributeValueId], references: [id], onDelete: Cascade)
  attribute             ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productAttributeValueId, locale])
  @@unique([attributeId, locale, slug])
  @@index([locale, attributeId])
}

model ProductIndustrialUsage {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sectorValueId String?
  sectorValue   ProductAttributeValue? @relation("ProductIndustrialUsageSector", fields: [sectorValueId], references: [id], onDelete: SetNull)

  productionGroupValueId String?
  productionGroupValue   ProductAttributeValue? @relation("ProductIndustrialUsageProductionGroup", fields: [productionGroupValueId], references: [id], onDelete: SetNull)

  usageAreaValueId String?
  usageAreaValue   ProductAttributeValue? @relation("ProductIndustrialUsageArea", fields: [usageAreaValueId], references: [id], onDelete: SetNull)

  usageFunction String? @db.Text
  imageKey      String?
  displayOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, displayOrder])
  @@index([sectorValueId])
  @@index([productionGroupValueId])
  @@index([usageAreaValueId])
}

model Customer {
  id String @id @default(uuid())

  companyName            String?
  fullName               String
  phone                  String
  email                  String
  note                   String?        @db.Text
  status                 CustomerStatus @default(LEAD)
  generalDiscountPercent Decimal?       @db.Decimal(5, 2)
  defaultPaymentTermDays Int?
  creditLimit            Decimal?       @db.Decimal(12, 2)
  paymentTermNote        String?        @db.Text

  assignedSalesUserId String?
  assignedSalesUser   User?   @relation("AssignedSalesUser", fields: [assignedSalesUserId], references: [id], onDelete: SetNull)

  convertedAt       DateTime?
  convertedByUserId String?
  convertedByUser   User?     @relation("CustomerConvertedBy", fields: [convertedByUserId], references: [id], onDelete: SetNull)

  sectorValueId String?
  sectorValue   ProductAttributeValue? @relation("CustomerSector", fields: [sectorValueId], references: [id], onDelete: SetNull)

  productionGroupValueId String?
  productionGroupValue   ProductAttributeValue? @relation("CustomerProductionGroup", fields: [productionGroupValueId], references: [id], onDelete: SetNull)

  usageAreaValues           ProductAttributeValue[]            @relation("CustomerUsageAreas")
  attributeValueAssignments CustomerAttributeValueAssignment[]
  companyContactAssignments CustomerCompanyContactAssignment[]
  portalUsers               User[]                             @relation("CustomerPortalUsers")
  userInvitations           UserInvitation[]
  featuredProducts          CustomerFeaturedProduct[]
  assignedProducts          CustomerAssignedProduct[]
  addresses                 CustomerAddress[]
  visits                    CustomerVisit[]
  businessRequests          BusinessRequest[]
  orders                    Order[]
  specialVariantPrices      CustomerVariantSpecialPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@index([assignedSalesUserId, status, createdAt])
  @@index([sectorValueId])
  @@index([productionGroupValueId])
}

model UserInvitation {
  id String @id @default(uuid())

  userId String
  user   User   @relation("CustomerPortalInvitationUser", fields: [userId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedByUser   User   @relation("CustomerPortalInvitationInvitedByUser", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  email                              String
  tokenHash                          String    @unique
  expiresAt                          DateTime
  acceptedAt                         DateTime?
  requestedFirstName                 String?
  requestedLastName                  String?
  requestedCustomerContactTitle      String?
  requestedCustomerContactDepartment String?
  requestedIsPrimaryCustomerContact  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, expiresAt])
  @@index([userId])
}

model CustomerAttributeValueAssignment {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  attributeValueId String
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  source CustomerAttributeValueAssignmentSource @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, attributeValueId])
  @@index([customerId])
  @@index([attributeValueId])
}

model CompanyContact {
  id String @id @default(uuid())

  department    String
  name          String
  roleLabel     String?
  email         String?
  phone         String?
  whatsappPhone String?
  note          String? @db.Text
  isActive      Boolean @default(true)
  displayOrder  Int     @default(0)

  customerAssignments CustomerCompanyContactAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@index([department])
}

model CustomerCompanyContactAssignment {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  companyContactId String
  companyContact   CompanyContact @relation(fields: [companyContactId], references: [id], onDelete: Cascade)

  isActive     Boolean @default(true)
  displayOrder Int     @default(0)
  note         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, companyContactId])
  @@index([customerId, isActive, displayOrder])
  @@index([companyContactId])
}

model GeoCountry {
  id               Int      @id
  name             String
  iso3             String?
  iso2             String   @unique
  numericCode      String?  @map("numeric_code")
  phoneCode        String?  @map("phonecode")
  capital          String?
  currency         String?
  currencyName     String?  @map("currency_name")
  currencySymbol   String?  @map("currency_symbol")
  tld              String?
  native           String?
  population       BigInt?
  gdp              String?
  region           String?
  regionId         Int?     @map("region_id")
  subregion        String?
  subregionId      Int?     @map("subregion_id")
  nationality      String?
  areaSqKm         String?  @map("area_sq_km")
  postalCodeFormat String?  @map("postal_code_format")
  postalCodeRegex  String?  @map("postal_code_regex")
  timezones        Json?
  latitude         Decimal? @db.Decimal(10, 8)
  longitude        Decimal? @db.Decimal(11, 8)
  emoji            String?
  emojiU           String?
  wikiDataId       String?

  states            GeoState[]
  cities            GeoCity[]
  customerAddresses CustomerAddress[]

  @@index([name])
  @@map("geo_countries")
}

model GeoState {
  id          Int      @id
  name        String
  countryId   Int      @map("country_id")
  countryCode String?  @map("country_code")
  countryName String?  @map("country_name")
  iso2        String?
  iso3166_2   String?
  fipsCode    String?  @map("fips_code")
  type        String?
  level       String?
  parentId    Int?     @map("parent_id")
  native      String?
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  timezone    String?
  wikiDataId  String?
  population  BigInt?

  country           GeoCountry        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  cities            GeoCity[]
  customerAddresses CustomerAddress[]

  @@index([countryId, name])
  @@index([countryCode])
  @@map("geo_states")
}

model GeoCity {
  id           Int      @id
  name         String
  stateId      Int?     @map("state_id")
  stateCode    String?  @map("state_code")
  stateName    String?  @map("state_name")
  countryId    Int      @map("country_id")
  countryCode  String?  @map("country_code")
  countryName  String?  @map("country_name")
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  native       String?
  type         String?
  level        String?
  parentId     Int?     @map("parent_id")
  population   BigInt?
  timezone     String?
  translations Json?
  wikiDataId   String?

  country           GeoCountry        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  state             GeoState?         @relation(fields: [stateId], references: [id], onDelete: SetNull)
  customerAddresses CustomerAddress[]

  @@index([countryId, name])
  @@index([stateId, name])
  @@map("geo_cities")
}

enum CustomerStatus {
  LEAD
  CUSTOMER
}

enum CustomerAttributeValueAssignmentSource {
  MANUAL
  LEGACY_BACKFILL
  SYSTEM
}

model WebRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  email   String
  phone   String?
  message String? @db.Text

  // B2B inquiry sepet snapshot (productId, variant info, quantity...)
  items Json

  status WebRequestStatus @default(NEW)

  @@index([email])
  @@index([status, createdAt])
}

enum WebRequestStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
}

///////////////////////////////////////////////////////
// PRODUCT VARIANT (10.11.B.V1)
///////////////////////////////////////////////////////

model ProductVariant {
  id String @id @default(uuid())

  name      String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  versionCode  String
  supplierCode String // 10.11.B
  variantIndex Int // 1, 2, 3...

  fullCode String @unique

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id])

  materials Material[]

  measurements ProductMeasurement[]
  assets       Asset[]

  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  variantSuppliers      ProductVariantSupplier[]
  assignedToCustomers   CustomerAssignedProduct[]
  requestItems          BusinessRequestItem[]
  orderItems            OrderItem[]
  customerSpecialPrices CustomerVariantSpecialPrice[]

  @@unique([productId, supplierCode, versionCode, variantIndex])
  @@index([productId])
  @@index([colorId])
}

///////////////////////////////////////////////////////
// MEASUREMENT TYPE
///////////////////////////////////////////////////////

enum MeasurementCode {
  D // Diameter (Çap) / Metrik (D)
  D1 // Metrik (D1)
  D2 // Metrik (D2)
  R // Radius (R) / Çap (R)
  R1 // Çap (R1)
  R2 // Çap (R2)
  L // Length (Uzunluk)
  L1 // Uzunluk (L1)
  L2 // Uzunluk (L2)
  T // Thickness (Kalınlık)
  A // Angle (Açı)
  W // Width (Genişlik)
  H // Height (Yükseklik) / Ürün Yüksekliği
  H1 // Ürün Yüksekliği (H1)
  H2 // Civata Uzunluğu (H2)
  PT // Profile Thickness (Profil Kalınlığı)
  M // Metric thread size (M8, M6...)
  R_L // R-L
}

model MeasurementType {
  id           String          @id @default(uuid())
  name         String
  code         MeasurementCode @unique
  baseUnit     String // mm, degree, kg
  displayOrder Int             @default(0)

  measurements ProductMeasurement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

///////////////////////////////////////////////////////
// PRODUCT MEASUREMENT
///////////////////////////////////////////////////////

model ProductMeasurement {
  id String @id @default(uuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  measurementTypeId String
  measurementType   MeasurementType @relation(fields: [measurementTypeId], references: [id])

  value Float
  label String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, measurementTypeId, label])
  @@index([variantId])
  @@index([measurementTypeId])
  @@index([measurementTypeId, value])
}

model Supplier {
  id String @id @default(uuid())

  name                        String
  contactName                 String?
  phone                       String?
  address                     String? @db.Text
  taxNumber                   String?
  defaultPaymentTermDays      Int?
  isActive                    Boolean @default(true)
  assignedPurchasingSuppliers User[]  @relation("SupplierPurchasingAssignments")

  variantSuppliers ProductVariantSupplier[]
  users            User[]
  businessRequests BusinessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model CustomerFeaturedProduct {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  displayOrder Int @default(0)

  createdByUserId String
  createdByUser   User   @relation("CustomerFeaturedProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, productId])
  @@index([customerId, displayOrder])
  @@index([productId])
  @@index([createdByUserId])
}

model CustomerAssignedProduct {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  displayOrder Int @default(0)

  createdByUserId String
  createdByUser   User   @relation("CustomerAssignedProductCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, productVariantId])
  @@index([customerId, displayOrder])
  @@index([productVariantId])
  @@index([createdByUserId])
}

model CustomerAddress {
  id String @id @default(uuid())

  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shippingOrders Order[]

  label                    String
  contactName              String?
  phone                    String?
  email                    String?
  countryId                Int?
  stateId                  Int?
  cityId                   Int?
  country                  String                           @default("Turkiye")
  city                     String
  district                 String?
  line1                    String
  line2                    String?
  postalCode               String?
  taxOffice                String?
  taxNumber                String?
  latitude                 Decimal?                         @db.Decimal(10, 8)
  longitude                Decimal?                         @db.Decimal(11, 8)
  locationSource           CustomerAddressLocationSource?
  locationAccuracy         CustomerAddressLocationAccuracy?
  geocodingProvider        String?
  geocodingPlaceId         String?
  geocodingLabel           String?
  geocodingRaw             Json?
  geocodedAt               DateTime?
  locationVerifiedAt       DateTime?
  locationVerifiedByUserId String?
  isPrimary                Boolean                          @default(false)
  isBilling                Boolean                          @default(false)
  isShipping               Boolean                          @default(true)
  note                     String?                          @db.Text
  displayOrder             Int                              @default(0)

  countryRef             GeoCountry? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  stateRef               GeoState?   @relation(fields: [stateId], references: [id], onDelete: SetNull)
  cityRef                GeoCity?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  locationVerifiedByUser User?       @relation("CustomerAddressVerifiedByUser", fields: [locationVerifiedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, displayOrder])
  @@index([customerId, isPrimary])
  @@index([countryId])
  @@index([stateId])
  @@index([cityId])
  @@index([latitude, longitude])
  @@index([locationVerifiedByUserId])
}

enum CustomerAddressLocationSource {
  MANUAL_PIN
  GEOCODED
  IMPORTED
  CUSTOMER_SUBMITTED
}

enum CustomerAddressLocationAccuracy {
  EXACT
  STREET
  DISTRICT
  CITY
  UNKNOWN
}

model GeocodingCache {
  id String @id @default(uuid())

  provider     String
  queryType    GeocodingCacheQueryType
  cacheKey     String
  responseJson Json
  expiresAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, queryType, cacheKey])
  @@index([expiresAt])
}

enum GeocodingCacheQueryType {
  SEARCH
  REVERSE
}

model CustomerVisit {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  ownerUserId String
  ownerUser   User   @relation("CustomerVisitOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  scheduledAt DateTime
  status      CustomerVisitStatus @default(PLANNED)
  title       String
  note        String?             @db.Text
  completedAt DateTime?

  createdByUserId String
  createdByUser   User   @relation("CustomerVisitCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, scheduledAt])
  @@index([customerId, status, scheduledAt])
  @@index([ownerUserId, status, scheduledAt])
  @@index([createdByUserId])
}

enum CustomerVisitStatus {
  PLANNED
  COMPLETED
  CANCELED
}

model ProductVariantSupplier {
  id String @id @default(uuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  isActive              Boolean   @default(false)
  price                 Decimal   @default(0) @db.Decimal(10, 2)
  operationalCostRate   Decimal?  @db.Decimal(5, 2)
  netCost               Decimal?  @db.Decimal(10, 2)
  profitRate            Decimal?  @db.Decimal(5, 2)
  listPrice             Decimal?  @db.Decimal(10, 2)
  paymentTermDays       Int?
  supplierVariantCode   String?
  supplierNote          String?   @db.Text
  pricingUpdatedAt      DateTime?
  minOrderQty           Int?
  stockQty              Int?
  availabilityUpdatedAt DateTime?
  currency              String    @default("TRY")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([variantId, supplierId])
  @@index([variantId])
  @@index([supplierId])
}

model CustomerVariantSpecialPrice {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  price    Decimal @db.Decimal(12, 2)
  currency String  @default("TRY")

  minOrderQuantity Int?
  maxOrderQuantity Int?

  paymentTermDays  Int?
  paymentTermLabel String?
  paymentSchedule  Json?

  validFrom  DateTime?
  validUntil DateTime?

  taxIncluded Boolean @default(false)

  deliveryTerm      String?
  contractReference String?
  note              String? @db.Text
  internalNote      String? @db.Text

  isActive Boolean @default(true)

  createdByUserId String
  createdByUser   User   @relation("CustomerVariantSpecialPriceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  approvedByUserId String?
  approvedByUser   User?     @relation("CustomerVariantSpecialPriceApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, productVariantId])
  @@index([customerId, isActive])
  @@index([productVariantId])
  @@index([validFrom, validUntil])
  @@index([createdByUserId])
  @@index([approvedByUserId])
}

enum BusinessRequestDomain {
  SALES
  PURCHASING
}

enum BusinessRequestType {
  CUSTOMER_PROFILE_CHANGE
  CUSTOMER_ORDER_REQUEST
  CUSTOMER_DOCUMENT_REQUEST
  CUSTOMER_PRICING_REQUEST
  SUPPLIER_PROFILE_CHANGE
  SUPPLIER_PRICING_CHANGE
  SUPPLIER_CAPABILITY_CHANGE
  SUPPLIER_CATEGORY_CREATE
  SUPPLIER_PRODUCT_CREATE
  SUPPLIER_VARIANT_CREATE
  OFFER_DISCOUNT_REQUEST
  PAYMENT_TERM_REQUEST
}

enum BusinessRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
  FAILED
}

enum BusinessRequestEntityType {
  CATEGORY
  CUSTOMER
  SUPPLIER
  PRODUCT
  PRODUCT_VARIANT
  ORDER
  OFFER
  PAYMENT_TERM
  DOCUMENT
  OTHER
}

enum BusinessRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  APPROVED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
}

enum ApprovalRole {
  CUSTOMER
  SUPPLIER
  SALES
  SALES_DIRECTOR
  PURCHASING
  ADMIN
  OWNER
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

model BusinessRequest {
  id String @id @default(cuid())

  domain   BusinessRequestDomain
  type     BusinessRequestType
  status   BusinessRequestStatus   @default(PENDING_APPROVAL)
  priority BusinessRequestPriority @default(NORMAL)

  title       String
  description String? @db.Text

  entityType BusinessRequestEntityType?
  entityId   String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  requestedByUserId String
  requestedByUser   User   @relation("BusinessRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)

  requesterRole ApprovalRole

  workflowExecutionArn String? @unique
  workflowTaskToken    String? @db.Text

  requestedData     Json
  currentSnapshot   Json?
  completedSnapshot Json?

  order Order?

  decidedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  items         BusinessRequestItem[]
  approvalSteps BusinessRequestApprovalStep[]
  activityLogs  ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain, status, createdAt])
  @@index([type, status, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([customerId, status, createdAt])
  @@index([supplierId, status, createdAt])
}

model Order {
  id String @id @default(cuid())

  orderNumber String      @unique
  status      OrderStatus @default(APPROVED)
  title       String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  requestedByUserId String?
  requestedByUser   User?   @relation("CustomerOrderRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  sourceRequestId String?          @unique
  sourceRequest   BusinessRequest? @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)

  shippingAddressId       String?
  shippingAddress         CustomerAddress? @relation(fields: [shippingAddressId], references: [id], onDelete: SetNull)
  shippingAddressLabel    String?
  shippingAddressSnapshot Json?

  referenceCode         String?
  currency              String    @default("TRY")
  totalQuantity         Int       @default(0)
  discountPercent       Decimal?  @db.Decimal(5, 2)
  listSubtotal          Decimal?  @db.Decimal(12, 2)
  customerSubtotal      Decimal?  @db.Decimal(12, 2)
  requestedDeliveryDate DateTime?
  paymentTermDays       Int?
  paymentTermNote       String?   @db.Text
  commercialNote        String?   @db.Text
  negotiationNote       String?   @db.Text
  approvedFromRequestAt DateTime?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([requestedByUserId, createdAt])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  quantity          Int      @default(1)
  listUnitPrice     Decimal? @db.Decimal(12, 2)
  customerUnitPrice Decimal? @db.Decimal(12, 2)
  listLineTotal     Decimal? @db.Decimal(12, 2)
  customerLineTotal Decimal? @db.Decimal(12, 2)
  currency          String   @default("TRY")
  note              String?  @db.Text
  data              Json?

  displayOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId, displayOrder])
  @@index([productVariantId])
}

model BusinessRequestItem {
  id String @id @default(uuid())

  requestId String
  request   BusinessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  quantity Int     @default(1)
  note     String? @db.Text
  data     Json?

  displayOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId, displayOrder])
  @@index([productVariantId])
}

model BusinessRequestApprovalStep {
  id String @id @default(cuid())

  requestId String
  request   BusinessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  stepOrder    Int
  requiredRole ApprovalRole

  assignedUserId String?
  assignedUser   User?   @relation("BusinessRequestStepAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  status ApprovalStepStatus @default(PENDING)

  decidedByUserId String?
  decidedByUser   User?     @relation("BusinessRequestStepDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  decisionNote    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requestId, stepOrder])
  @@index([assignedUserId, status, createdAt])
  @@index([requiredRole, status, createdAt])
  @@index([decidedByUserId, createdAt])
}

model ActivityLog {
  id String @id @default(cuid())

  requestId String?
  request   BusinessRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  actorUserId String?
  actorUser   User?   @relation("ActivityLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  source      String
  eventType   String
  title       String
  description String? @db.Text
  data        Json?

  createdAt DateTime @default(now())

  @@index([requestId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
}

model Material {
  id String @id @default(uuid())

  name String
  code String? // PP, PE, PVC gibi

  variants ProductVariant[]
  assets   Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

enum AssetType {
  IMAGE
  VIDEO
  PDF
  TECHNICAL_DRAWING
  CERTIFICATE
}

enum AssetRole {
  PRIMARY
  ANIMATION
  GALLERY
  DOCUMENT
  TECHNICAL_DRAWING
  MODEL_3D
  ASSEMBLY_VIDEO
  CERTIFICATE
}

// kaldırıldı
// isPrimary Boolean   @default(false)
model Asset {
  id String @id @default(uuid())

  key      String // S3 key
  mimeType String // image/png, image/gif, application/pdf
  type     AssetType
  role     AssetRole

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  productAttributeValueId String?
  productAttributeValue   ProductAttributeValue? @relation(fields: [productAttributeValueId], references: [id], onDelete: Cascade)

  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([productId])
  @@index([variantId])
  @@index([productAttributeValueId])
  @@index([materialId])
}
