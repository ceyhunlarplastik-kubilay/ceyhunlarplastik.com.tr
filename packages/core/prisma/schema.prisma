// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////

model User {
  id         String   @id @default(uuid())
  cognitoSub String   @unique
  email      String   @unique
  identifier String
  groups     String[]
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

///////////////////////////////////////////////////////
// COLOR
///////////////////////////////////////////////////////

model Color {
  id       String      @id @default(uuid())
  system   ColorSystem @default(RAL)
  code     String
  name     String
  hex      String
  rgbR     Int?
  rgbG     Int?
  rgbB     Int?
  isActive Boolean     @default(true)

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([system, code])
}

enum ColorSystem {
  RAL
  PANTONE
  NCS
  CUSTOM
}

///////////////////////////////////////////////////////
// CATEGORY
///////////////////////////////////////////////////////

model Category {
  id   String @id @default(uuid())
  code Int
  name String
  slug String @unique
  allowedAttributeValueIds String[] @default([])

  products Product[]
  assets   Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
}

///////////////////////////////////////////////////////
// PRODUCT (10.11)
///////////////////////////////////////////////////////

model Product {
  id String @id @default(uuid())

  code String // 10.11
  name String
  slug String @unique

  description String? @db.Text

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  variants        ProductVariant[]
  assets          Asset[]
  attributeValues ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
  @@index([categoryId])
}

model ProductAttribute {
  id String @id @default(uuid())

  code String @unique // usage_area, model_type, connection_type, profile_type, material_type, usage_type, hat_type
  name String

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  values ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductAttributeValue {
  id String @id @default(uuid())

  name String
  slug String

  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  parentValueId String?
  parentValue   ProductAttributeValue?  @relation("AttributeValueHierarchy", fields: [parentValueId], references: [id], onDelete: SetNull)
  childValues   ProductAttributeValue[] @relation("AttributeValueHierarchy")

  // 🔥 MANY TO MANY
  products Product[]
  assets   Asset[]
  customerSectors          Customer[] @relation("CustomerSector")
  customerProductionGroups Customer[] @relation("CustomerProductionGroup")
  customerUsageAreas       Customer[] @relation("CustomerUsageAreas")

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attributeId, name])
  @@index([attributeId])
  @@index([parentValueId])
}

model Customer {
  id String @id @default(uuid())

  companyName String?
  fullName    String
  phone       String
  email       String
  note        String? @db.Text

  sectorValueId String?
  sectorValue   ProductAttributeValue? @relation("CustomerSector", fields: [sectorValueId], references: [id], onDelete: SetNull)

  productionGroupValueId String?
  productionGroupValue   ProductAttributeValue? @relation("CustomerProductionGroup", fields: [productionGroupValueId], references: [id], onDelete: SetNull)

  usageAreaValues ProductAttributeValue[] @relation("CustomerUsageAreas")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([sectorValueId])
  @@index([productionGroupValueId])
}

model WebRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  email   String
  phone   String?
  message String? @db.Text

  // B2B inquiry sepet snapshot (productId, variant info, quantity...)
  items Json

  status WebRequestStatus @default(NEW)

  @@index([email])
  @@index([status, createdAt])
}

enum WebRequestStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
}

///////////////////////////////////////////////////////
// PRODUCT VARIANT (10.11.B.V1)
///////////////////////////////////////////////////////

model ProductVariant {
  id String @id @default(uuid())

  name      String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  versionCode  String
  supplierCode String // 10.11.B
  variantIndex Int // 1, 2, 3...

  fullCode String @unique

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id])

  materials Material[]

  measurements ProductMeasurement[]
  assets       Asset[]

  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  variantSuppliers ProductVariantSupplier[]

  @@unique([productId, supplierCode, versionCode, variantIndex])
  @@index([productId])
  @@index([colorId])
}

///////////////////////////////////////////////////////
// MEASUREMENT TYPE
///////////////////////////////////////////////////////

enum MeasurementCode {
  D // Diameter (Çap) / Metrik (D)
  D1 // Metrik (D1)
  D2 // Metrik (D2)
  R // Radius (R) / Çap (R)
  R1 // Çap (R1)
  R2 // Çap (R2)
  L // Length (Uzunluk)
  L1 // Uzunluk (L1)
  L2 // Uzunluk (L2)
  T // Thickness (Kalınlık)
  A // Angle (Açı)
  W // Width (Genişlik)
  H // Height (Yükseklik) / Ürün Yüksekliği
  H1 // Ürün Yüksekliği (H1)
  H2 // Civata Uzunluğu (H2)
  PT // Profile Thickness (Profil Kalınlığı)
  M // Metric thread size (M8, M6...)
  R_L // R-L
}

model MeasurementType {
  id           String          @id @default(uuid())
  name         String
  code         MeasurementCode @unique
  baseUnit     String // mm, degree, kg
  displayOrder Int             @default(0)

  measurements ProductMeasurement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

///////////////////////////////////////////////////////
// PRODUCT MEASUREMENT
///////////////////////////////////////////////////////

model ProductMeasurement {
  id String @id @default(uuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  measurementTypeId String
  measurementType   MeasurementType @relation(fields: [measurementTypeId], references: [id])

  value Float
  label String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, measurementTypeId, label])
  @@index([variantId])
  @@index([measurementTypeId])
  @@index([measurementTypeId, value])
}

model Supplier {
  id String @id @default(uuid())

  name     String
  contactName String?
  phone String?
  address String? @db.Text
  taxNumber String?
  defaultPaymentTermDays Int?
  isActive Boolean @default(true)

  variantSuppliers ProductVariantSupplier[]
  users            User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model ProductVariantSupplier {
  id String @id @default(uuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  isActive Boolean @default(false)
  price    Decimal @default(0) @db.Decimal(10, 2)
  operationalCostRate Decimal? @db.Decimal(5, 2)
  netCost Decimal? @db.Decimal(10, 2)
  profitRate Decimal? @db.Decimal(5, 2)
  listPrice Decimal? @db.Decimal(10, 2)
  paymentTermDays Int?
  supplierVariantCode String?
  supplierNote String? @db.Text
  pricingUpdatedAt DateTime?
  minOrderQty Int?
  stockQty Int?
  availabilityUpdatedAt DateTime?
  currency String  @default("TRY")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, supplierId])
  @@index([variantId])
  @@index([supplierId])
}

model Material {
  id String @id @default(uuid())

  name String
  code String? // PP, PE, PVC gibi

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

enum AssetType {
  IMAGE
  VIDEO
  PDF
  TECHNICAL_DRAWING
  CERTIFICATE
}

enum AssetRole {
  PRIMARY
  ANIMATION
  GALLERY
  DOCUMENT
  TECHNICAL_DRAWING
  MODEL_3D
  ASSEMBLY_VIDEO
  CERTIFICATE
}

// kaldırıldı
// isPrimary Boolean   @default(false)
model Asset {
  id String @id @default(uuid())

  key      String // S3 key
  mimeType String // image/png, image/gif, application/pdf
  type     AssetType
  role     AssetRole

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  productAttributeValueId String?
  productAttributeValue   ProductAttributeValue? @relation(fields: [productAttributeValueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([productId])
  @@index([variantId])
  @@index([productAttributeValueId])
}
